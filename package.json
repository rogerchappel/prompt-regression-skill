{
  "name": "prompt-regression-skill",
  "version": "0.1.0",
  "description": "Local-first agent skill for checking prompt-output regressions from fixture cases.",
  "type": "module",
  "bin": {
    "prompt-regression-skill": "./bin/prompt-regression-skill.js"
  },
  "scripts": {
    "check": "node --check src/core.js && node --check bin/prompt-regression-skill.js",
    "test": "node --test",
    "smoke": "node bin/prompt-regression-skill.js fixtures/pass-cases.json --format text",
    "demo:failures": "node bin/prompt-regression-skill.js fixtures/cases.json --format text",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "prompt",
    "regression",
    "evals"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/prompt-regression-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/prompt-regression-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/prompt-regression-skill#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "docs",
    "fixtures",
    "src",
    "SKILL.md",
    "README.md"
  ]
}
